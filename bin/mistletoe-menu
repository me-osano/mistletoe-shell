}

show_install_ai_menu() {
  ollama_pkg=$(
    (command -v nvidia-smi &>/dev/null && echo ollama-cuda) ||
      (command -v rocminfo &>/dev/null && echo ollama-rocm) ||
      echo ollama
  )

  case $(menu "Install" "ю░Т  Dictation\nґ▒Ъд  Claude Code\nґ▒Ъд  Copilot CLI\nґ▒Ъд  Cursor CLI\nґ▒Ъд  Gemini\nґ▒Ъд  OpenAI Codex\nґ▒Ъд  LM Studio\nґ▒Ъд  Ollama\nґ▒Ъд  Crush") in
  *Dictation*) present_terminal mistletoe-voxtype-install ;;
  *Claude*) install "Claude Code" "claude-code" ;;
  *Copilot*) install "Copilot CLI" "github-copilot-cli" ;;
  *Cursor*) install "Cursor CLI" "cursor-cli" ;;
  *Gemini*) install "Gemini" "gemini-cli" ;;
  *OpenAI*) install "OpenAI Codex" "openai-codex" ;;
  *Studio*) install "LM Studio" "lmstudio" ;;
  *Ollama*) install "Ollama" $ollama_pkg ;;
  *Crush*) install "Crush" "crush-bin" ;;
  *) show_install_menu ;;
  esac
}

