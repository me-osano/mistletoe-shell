  case $(menu "Install" "яЖ╢  Steam\nґ░в╣  NVIDIA GeForce NOW\nяДЫ  RetroArch [AUR]\nґ░Н│  Minecraft\nґ░Ц║  Xbox Controller [AUR]") in
  *Steam*) present_terminal mistletoe-install-steam ;;
  *GeForce*) present_terminal mistletoe-install-geforce-now ;;
  *RetroArch*) aur_install_and_launch "RetroArch" "retroarch retroarch-assets libretro libretro-fbneo" "com.libretro.RetroArch.desktop" ;;
  *Minecraft*) install_and_launch "Minecraft" "minecraft-launcher" "minecraft-launcher" ;;
  *Xbox*) present_terminal mistletoe-install-xbox-controllers ;;
  *) show_install_menu ;;
  esac
}

