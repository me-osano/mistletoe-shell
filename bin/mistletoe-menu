  case $(menu "Update" "яМГ  Mistletoe\nюШХ  Config\nґ░╕М  Extra Themes\nюов  Process\nґ░ЗЕ  Hardware\nюй╕  Firmware\nюмС  Password\nюмБ  Timezone\nюОГ  Time") in
