#!/usr/bin/env bash

# Launch the Mistletoe Menu or takes a parameter to jump straight to a submenu.

export PATH="$HOME/.local/share/mistletoe/bin:$PATH"

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ "$BACK_TO_EXIT" == "true" ]]; then
    exit 0
  elif [[ -n "$parent_menu" ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n "$preselect" ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n "$index" ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" | mistletoe-launch-walker --dmenu --width 295 --minheight 1 --maxheight 630 -p "$promptтАж" "${args[@]}" 2>/dev/null
}

terminal() {
  xdg-terminal-exec --app-id=org.mistletoe.terminal "$@"
}

present_terminal() {
  mistletoe-launch-floating-terminal-with-presentation $1
}

open_in_editor() {
  notify-send "Editing config file" "$1"
  mistletoe-launch-editor "$1"
}

install() {
  present_terminal "echo 'Installing $1...'; sudo pacman -S --noconfirm $2"
}

install_and_launch() {
  present_terminal "echo 'Installing $1...'; sudo pacman -S --noconfirm $2 && setsid gtk-launch $3"
}

install_font() {
  present_terminal "echo 'Installing $1...'; sudo pacman -S --noconfirm --needed $2 && sleep 2 && mistletoe-font-set '$3'"
}

install_terminal() {
  present_terminal "mistletoe-install-terminal $1"
}

aur_install() {
  present_terminal "echo 'Installing $1 from AUR...'; yay -S --noconfirm $2"
}

aur_install_and_launch() {
  present_terminal "echo 'Installing $1 from AUR...'; yay -S --noconfirm $2 && setsid gtk-launch $3"
}

show_learn_menu() {
  case $(menu "Learn" "яДЬ  Keybindings\nяРЕ  Hyprland\nґ░гЗ  Arch\nюЪо  Neovim\nґ▒ЖГ  Bash") in
  *Keybindings*) mistletoe-menu-keybindings ;;
  *Hyprland*) mistletoe-launch-webapp "https://wiki.hypr.land/" ;;
  *Arch*) mistletoe-launch-webapp "https://wiki.archlinux.org/title/Main_page" ;;
  *Bash*) mistletoe-launch-webapp "https://devhints.io/bash" ;;
  *Neovim*) mistletoe-launch-webapp "https://www.lazyvim.org/keymaps" ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "яА░  Capture\nяФО  Share\nґ░ФО  Toggle") in
  *Capture*) show_capture_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *) show_main_menu ;;
  esac
}

show_capture_menu() {
  case $(menu "Capture" "яА░  Screenshot\nяА╜  Screenrecord\nґ░ГЙ  Color") in
  *Screenshot*) show_screenshot_menu ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Color*) pkill hyprpicker || hyprpicker -a ;;
  *) show_trigger_menu ;;
  esac
}

show_screenshot_menu() {
  case $(menu "Screenshot" "яА░  Snap with Editing\nяА░  Straight to Clipboard") in
  *Editing*) mistletoe-cmd-screenshot smart ;;
  *Clipboard*) mistletoe-cmd-screenshot smart clipboard ;;
  *) show_capture_menu ;;
  esac
}

get_webcam_list() {
  v4l2-ctl --list-devices 2>/dev/null | while IFS= read -r line; do
    if [[ "$line" != $'\t'* && -n "$line" ]]; then
      local name="$line"
      IFS= read -r device || break
      device=$(echo "$device" | tr -d '\t' | head -1)
      [[ -n "$device" ]] && echo "$device  $name"
    fi
  done
}

show_webcam_select_menu() {
  local devices=$(get_webcam_list)
  local count=$(echo "$devices" | grep -c . 2>/dev/null || echo 0)

  if [[ -z "$devices" || "$count" -eq 0 ]]; then
    notify-send "No webcam devices found" -u critical -t 3000
    return 1
  fi

  if [[ "$count" -eq 1 ]]; then
    echo "$devices" | awk '{print $1}'
  else
    menu "Select Webcam" "$devices" | awk '{print $1}'
  fi
}

show_screenrecord_menu() {
  mistletoe-cmd-screenrecord --stop-recording && exit 0

  case $(menu "Screenrecord" "яА╜  With desktop audio\nяА╜  With desktop + microphone audio\nяА╜  With desktop + microphone audio + webcam") in
  *"With desktop audio") mistletoe-cmd-screenrecord --with-desktop-audio ;;
  *"With desktop + microphone audio") mistletoe-cmd-screenrecord --with-desktop-audio --with-microphone-audio ;;
  *"With desktop + microphone audio + webcam")
    local device=$(show_webcam_select_menu) || { back_to show_capture_menu; return; }
    mistletoe-cmd-screenrecord --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
    ;;
  *) back_to show_capture_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "яБ┐  Clipboard\nюй╗  File \nяДФ  Folder") in
  *Clipboard*) mistletoe-cmd-share clipboard ;;
  *File*) terminal bash -c "mistletoe-cmd-share file" ;;
  *Folder*) terminal bash -c "mistletoe-cmd-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  case $(menu "Toggle" "ґ▒ДД  Screensaver\nґ░ФО  Nightlight\nґ▒лЦ  Idle Lock\nґ░НЬ  Top Bar") in
  *Screensaver*) mistletoe-toggle-screensaver ;;
  *Nightlight*) mistletoe-toggle-nightlight ;;
  *Idle*) mistletoe-toggle-idle ;;
  *Bar*) mistletoe-toggle-waybar ;;
  *) show_trigger_menu ;;
  esac
}

show_style_menu() {
  case $(menu "Style" "ґ░╕М  Theme\nюЩЩ  Font\nяА╛  Background\nяНЩ  Hyprland\nґ▒ДД  Screensaver\nюй┤  About") in
  *Theme*) show_theme_menu ;;
  *Font*) show_font_menu ;;
  *Background*) mistletoe-theme-bg-next ;;
  *Hyprland*) open_in_editor ~/.config/hypr/general.conf ;;
  *Screensaver*) open_in_editor ~/.config/mistletoe/branding/screensaver.txt ;;
  *About*) open_in_editor ~/.config/mistletoe/branding/about.txt ;;
  *) show_main_menu ;;
  esac
}

show_theme_menu() {
  theme=$(menu "Theme" "$(mistletoe-theme-list)" "" "$(mistletoe-theme-current)")
  if [[ "$theme" == "CNCLD" || -z "$theme" ]]; then
    back_to show_style_menu
  else
    mistletoe-theme-set "$theme"
  fi
}

show_font_menu() {
  theme=$(menu "Font" "$(mistletoe-font-list)" "--width 350" "$(mistletoe-font-current)")
  if [[ "$theme" == "CNCLD" || -z "$theme" ]]; then
    back_to show_style_menu
  else
    mistletoe-font-set "$theme"
  fi
}

show_setup_menu() {
  local options="юШ╕  Audio\nяЗл  Wifi\nґ░Вп  Bluetooth\nґ▒РЛ  Power\nґ░Н╣  Monitors"
  [ -f ~/.config/hypr/keybindings.conf ] && options="$options\nяДЬ  Keybindings"
  [ -f ~/.config/hypr/input.conf ] && options="$options\nю╛║  Input"
  [ -f ~/.config/hypr/windowrules.conf ] && options="$options\nґ░Н╣   WindowRules"
  options="$options\nґ░▒Ф  DNS\nюмС  Security\nюШХ  Config"

  case $(menu "Setup" "$options") in
  *Audio*) mistletoe-launch-audio ;;
  *Wifi*) mistletoe-launch-wifi ;;
  *Bluetooth*) mistletoe-launch-bluetooth ;;
  *Power*) show_setup_power_menu ;;
  *Monitors*) open_in_editor ~/.config/hypr/monitors.conf ;;
  *Keybindings*) open_in_editor ~/.config/hypr/keybindings.conf ;;
  *Input*) open_in_editor ~/.config/hypr/input.conf ;;
  *WindowRules*) open_in_editor ~/.config/hypr/windowrules.conf ;;
  *DNS*) present_terminal mistletoe-setup-dns ;;
  *Security*) show_setup_security_menu ;;
  *Config*) show_setup_config_menu ;;
  *) show_main_menu ;;
  esac
}

show_setup_power_menu() {
  case $(menu "Power" "ґ▒РЛ Tlp\nґ▒РЛ  Power Profiles") in
  *Tlp*) present_terminal mistletoe-setup-tlp ;;
  *PPD*) present_terminal mistletoe-setup-ppd ;;
  esac
}

show_setup_security_menu() {
  case $(menu "Setup" "ґ░И╖  Fingerprint\nюмС  Fido2\nюмС  Secureboot\nюмС  Apparmor\nюмС") in
  *Fingerprint*) present_terminal mistletoe-setup-fingerprint ;;
  *Fido2*) present_terminal mistletoe-setup-fido2 ;;
  *Secureboot*) present_terminal mistletoe-setup-secureboot ;;
  *Apparmor*) present_terminal mistletoe-setup-apparmor ;;
  *) show_setup_menu ;;
  esac
}

show_setup_config_menu() {
  case $(menu "Setup" "яТЙ  Bash\nяНЩ  Hyprland\nяНЩ  Hypridle\nяНЩ  Hyprlock\nяНЩ  Hyprsunset\nяНЭ  Swayosd\nґ░Мз  Walker\nґ░НЬ  Waybar\nґ░ЮЕ  XCompose") in
  *Bash*) open_in_editor ~/.bashrc ;;
  *Hyprland*) open_in_editor ~/.config/hypr/hyprland.conf ;;
  *Hypridle*) open_in_editor ~/.config/hypr/hypridle.conf && mistletoe-restart-hypridle ;;
  *Hyprlock*) open_in_editor ~/.config/hypr/hyprlock.conf ;;
  *Hyprsunset*) open_in_editor ~/.config/hypr/hyprsunset.conf && mistletoe-restart-hyprsunset ;;
  *Swayosd*) open_in_editor ~/.config/swayosd/config.toml && mistletoe-restart-swayosd ;;
  *Walker*) open_in_editor ~/.config/walker/config.toml && mistletoe-restart-walker ;;
  *Waybar*) open_in_editor ~/.config/waybar/config.jsonc && mistletoe-restart-waybar ;;
  *XCompose*) open_in_editor ~/.XCompose && mistletoe-restart-xcompose ;;
  *) show_setup_menu ;;
  esac
}

