  esac
}

show_update_config_menu() {
  case $(menu "Use default config" "яНЩ  Hyprland\nяНЩ  Hypridle\nяНЩ  Hyprlock\nяНЩ  Hyprsunset\nяНЭ  Swayosd\nґ░Мз  Walker\nґ░НЬ  Waybar") in
  *Hyprland*) present_terminal mistletoe-refresh-hyprland ;;
  *Hypridle*) present_terminal mistletoe-refresh-hypridle ;;
  *Hyprlock*) present_terminal mistletoe-refresh-hyprlock ;;
  *Hyprsunset*) present_terminal mistletoe-refresh-hyprsunset ;;
  *Swayosd*) present_terminal mistletoe-refresh-swayosd ;;
  *Walker*) present_terminal mistletoe-refresh-walker ;;
  *Waybar*) present_terminal mistletoe-refresh-waybar ;;
  *) show_update_menu ;;
  esac
}

show_update_hardware_menu() {
  case $(menu "Restart" "юШ╕  Audio\nґ▒Ъ╛  Wi-Fi\nґ░Вп  Bluetooth") in
  *Audio*) present_terminal mistletoe-restart-pipewire ;;
  *Wi-Fi*) present_terminal mistletoe-restart-wifi ;;
  *Bluetooth*) present_terminal mistletoe-restart-bluetooth ;;
  *) show_update_menu ;;
  esac
}

show_update_password_menu() {
  case $(menu "Update Password" "юмС  Drive Encryption\nюмС  User") in
  *Drive*) present_terminal mistletoe-drive-set-password ;;
  *User*) present_terminal passwd ;;
  *) show_update_menu ;;
  esac
}

show_about() {
  mistletoe-launch-about
}

show_system_menu() {
  local options="яАг  Lock\nґ▒ДД  Screensaver"
  [ -f ~/.local/state/mistletoe/toggles/suspend-on ] && options="$options\nґ░Т▓  Suspend"
  mistletoe-hibernation-available && options="$options\nґ░дБ  Hibernate"
  options="$options\nґ░ЬЙ  Reboot\nґ░Ре  Shutdown"

  case $(menu "System" "$options") in
  *Lock*) mistletoe-lock-screen ;;
  *Screensaver*) mistletoe-launch-screensaver force ;;
  *Suspend*) systemctl suspend ;;
  *Hibernate*) systemctl hibernate ;;
  *Reboot*) mistletoe-cmd-reboot ;;
  *Shutdown*) mistletoe-cmd-shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

show_main_menu() {
  go_to_menu "$(menu "Go" "ґ░А╗  Apps\nґ░зС  Learn\nґ▒УЮ  Trigger\nюпП  Style\nюШХ  Setup\nґ░ЙЙ  Install\nґ░нМ  Remove\nяАб  Update\nюй┤  About\nяАС  System")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*) walker -p "LaunchтАж" ;;
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *share*) show_share_menu ;;
  *capture*) show_capture_menu ;;
  *style*) show_style_menu ;;
  *theme*) show_theme_menu ;;
  *screenshot*) show_screenshot_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  *setup*) show_setup_menu ;;
  *power*) show_setup_power_menu ;;
  *install*) show_install_menu ;;
  *remove*) show_remove_menu ;;
  *update*) show_update_menu ;;
  *about*) show_about ;;
  *system*) show_system_menu ;;
  esac
}

if [[ -n "$1" ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi