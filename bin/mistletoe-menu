  case $(menu "Restart" "яНЩ  Hypridle\nяНЩ  Hyprsunset\nяНЭ  Swayosd\nґ░Мз  Walker\nґ░НЬ  Waybar") in
  *Hypridle*) mistletoe-restart-hypridle ;;
  *Hyprsunset*) mistletoe-restart-hyprsunset ;;
  *Swayosd*) mistletoe-restart-swayosd ;;
  *Walker*) mistletoe-restart-walker ;;
  *Waybar*) mistletoe-restart-waybar ;;
